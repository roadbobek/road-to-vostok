[navigation]

3d/warnings/navmesh_edge_merge_errors=false
3d/warnings/navmesh_cell_size_mismatch=false
3d/default_cell_size=0.12
3d/default_cell_height=0.12
3d/merge_rasterizer_cell_scale=0.001
3d/use_edge_connections=false
3d/default_edge_connection_margin=0.1

[physics]

common/physics_ticks_per_second=120
3d/default_linear_damp=1.0
3d/default_angular_damp=1.0

[rendering]

rendering_device/staging_buffer/max_size_mb=256
textures/canvas_textures/default_texture_filter=2
rendering_device/driver.windows="d3d12"
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=3
reflections/sky_reflections/roughness_layers=7
reflections/sky_reflections/texture_array_reflections=false
textures/default_filters/anisotropic_filtering_level=3
environment/ssao/quality=1
environment/ssao/blur_passes=4
environment/ssil/quality=1
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/smaa_edge_detection_threshold=0.01
anti_aliasing/quality/use_debanding=true
textures/decals/filter=5
environment/subsurface_scattering/subsurface_scattering_quality=0
global_illumination/sdfgi/probe_ray_count=0
lights_and_shadows/positional_shadow/atlas_quadrant_2_subdiv=2
lights_and_shadows/positional_shadow/atlas_quadrant_3_subdiv=2

[shader_globals]

Winter={
"type": "bool",
"value": false
}
Player={
"type": "vec3",
"value": Vector3(0, 0, 0)
}
Wind={
"type": "float",
"value": 0.0
}
Snow={
"type": "float",
"value": 0.0
}
Noise={
"type": "sampler2D",
"value": "res://Terrains/Textures/TX_Mask_Noise.png"
}
Specular={
"type": "sampler2D",
"value": "res://Modular/Textures/TX_Specular.png"
}
Overlay={
"type": "sampler2D",
"value": "res://Terrains/Textures/TX_Mask_Overlay.png"
}
SnowNormal={
"type": "sampler2D",
"value": "res://Terrains/Textures/TX_Snow_NR.png"
}
Rain={
"type": "float",
"value": 0.0
}
Ripples={
"type": "sampler2D",
"value": "res://Modular/Textures/TX_Ripples.png"
}
Indoor={
"type": "float",
"value": 0.0
}
Viewmodel={
"type": "float",
"value": 50.0
}
Occlusion={
"type": "bool",
"value": true
}
Compatibility={
"type": "bool",
"value": false
}
