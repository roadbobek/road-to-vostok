; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Roadbobek - Road to Vostok"
config/version="0.1.1.3"
run/main_scene="uid://dk7wi3k5t7csr"
config/use_custom_user_dir=true
config/custom_user_dir_name="Road to Vostok"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=120
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/image="uid://bk0f0a7hsb1k3"
config/icon="res://Editor/RTV_Icon.png"
config/windows_native_icon="res://Editor/RTV_Icon.ico"

[audio]

buses/default_bus_layout="uid://bue7w362pevv5"

[autoload]

ModLoaderStore="*uid://dq2jxrig04fqx"
ModLoader="*uid://cfhuho48bcyyi"
Loader="*res://Resources/Loader.tscn"
Database="*res://Resources/Database.tscn"
Simulation="*res://Resources/Simulation.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor]

naming/node_name_num_separator=2

[editor_overrides]

text_editor/behavior/indent/type=1

[editor_plugins]

enabled=PackedStringArray("res://addons/mod_loader/_export_plugin/plugin.cfg", "res://addons/mod_tool/plugin.cfg")

[filesystem]

import/blender/enabled=false
import/fbx/enabled=false

[global_group]

Furniture=""
Interactable=""
Item=""
AI_CP=""
AI_PP=""
AI_HP=""
AI_SP=""
AI_WP=""
AI_GP=""
AI=""
Player=""
AI_BTR=""
Transition=""
Switch=""
Display=""
Blocker=""
Trader=""
AI_VP=""
Radio=""
Well=""
Cat=""

[gui]

common/snap_controls_to_pixels=false

[importer_defaults]

texture={
"compress/channel_pack": 0,
"compress/hdr_compression": 1,
"compress/high_quality": false,
"compress/lossy_quality": 0.7,
"compress/mode": 2,
"compress/normal_map": 0,
"detect_3d/compress_to": 0,
"mipmaps/generate": true,
"mipmaps/limit": -1,
"process/fix_alpha_border": true,
"process/hdr_as_srgb": false,
"process/hdr_clamp_exposure": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"process/size_limit": 0,
"roughness/mode": 0,
"roughness/src_normal": ""
}
wavefront_obj={
"force_disable_mesh_compression": false,
"generate_lightmap_uv2": false,
"generate_lightmap_uv2_texel_size": 0.2,
"generate_lods": false,
"generate_shadow_mesh": true,
"generate_tangents": true,
"offset_mesh": Vector3(0, 0, 0),
"optimize_mesh": true,
"scale_mesh": Vector3(1, 1, 1)
}

