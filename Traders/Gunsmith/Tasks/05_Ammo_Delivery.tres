[resource]
script = ExtResource("6")
trader = "Gunsmith"
name = "Ammo Delivery"
difficulty = "Intermediate"
description = "You will find most of the ammo types in my stock. Whether you're into squirrel hunting or human hunting, there are options for all.

When it comes to ammo, 7.62x39 and .223 are the best sellers by a big margin. Sometimes there are still those annoying customers who seek something more exotic, but it's hard to maintain a stock for every weird request.

Maybe you could do a quick ammo delivery run for me? We could expand the portfolio a bit, so to speak."
deliver = [ExtResource("1"), ExtResource("2"), ExtResource("3")]
receive = [ExtResource("4"), ExtResource("5")]
metadata/_custom_type_script = "uid://ys7u8u54lq8b"
