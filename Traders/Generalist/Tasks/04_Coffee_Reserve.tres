[resource]
script = ExtResource("6")
trader = "Generalist"
name = "Coffee Reserve"
difficulty = "Easy"
description = "There are few things in life that are non-negotiable. There's morning coffee at 6:00, afternoon coffee at 12:00 and dinner coffee at 18:00. When manual labor is involved, coffee breaks in between are also mandatory and basically prescribed by law.

If you want to remain alive here in Area 05, the constant flow of caffeine should be your primary goal.

As a matter of fact, I should probably increase my strategic coffee reserve a bit, since the consumption lately has been above average."
deliver = [ExtResource("1"), ExtResource("2")]
receive = [ExtResource("3"), ExtResource("4"), ExtResource("5")]
metadata/_custom_type_script = "uid://ys7u8u54lq8b"
