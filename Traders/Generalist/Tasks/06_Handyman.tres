[resource]
script = ExtResource("10")
trader = "Generalist"
name = "Handyman"
difficulty = "Intermediate"
description = "You know that old lady who still lives near the Border Zone? Well, she's blind and no matter how many times I have warned her about electronics, she keeps fiddling around with different buttons and then everything gets messed up!

Now there's a broken stove, the freezer has melted and apparently the radio is once again \"misbehaving.\" On top of this, during a storm last week, a tree fell directly onto her porch roof and it has now somewhat collapsed, so we are dealing with a clusterfuck of issues.

I'm getting tired of being her handyman, but I promised to help this one last time."
deliver = [ExtResource("1"), ExtResource("2"), ExtResource("3"), ExtResource("4"), ExtResource("5")]
receive = [ExtResource("6"), ExtResource("7"), ExtResource("8"), ExtResource("9")]
metadata/_custom_type_script = "uid://ys7u8u54lq8b"
