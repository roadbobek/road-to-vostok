script = ExtResource("1")
day = 10
name = "Gunsmith returns to Outpost"
type = "Trader"
map = "Outpost"
function = "ActivateTrader"
description = "Gunsmith is a trader who maintains a weapon storage inside one of the Outpost bunkers and specializes in everything related to firearms.

Gunsmith was nowhere to be seen for multiple months but according to rumors, he was taking a \"business trip\" to the other side of the border but has now returned to his beloved bunker in Area 05."
